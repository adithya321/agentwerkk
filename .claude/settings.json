{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'test -f tsconfig.json || exit 0; set -o pipefail; npx tsc --noEmit 2>&1 | head -30'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-env-local.sh"
          }
        ]
      }
    ]
  }
}
